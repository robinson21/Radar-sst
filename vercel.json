{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "runtime": "@vercel/node",
      "maxDuration": 120
    },
    "api/cron/scan.ts": {
      "runtime": "@vercel/node",
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/cron/scan",
      "schedule": "0 9 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
